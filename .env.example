# Supabase Postgres — for Drizzle (direct DB connection, contains your DB password).
# Both point at the same DB; copy them from the Supabase "Connect" dialog.
DATABASE_URL=   # app runtime — transaction pooler (port 6543)
DIRECT_URL=     # migrations — direct connection (port 5432)

# Supabase API — client-side, exposed to the browser (safe: publishable key).
# Used by the resumable video upload (browser → Storage) and, later, Realtime.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Twelve Labs — for later (AI indexing + webhooks).
# TWELVE_LABS_API_KEY=
# TWELVE_LABS_WEBHOOK_SECRET=
